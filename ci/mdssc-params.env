# ============================================================
# MDSSC Pipeline — Parametri configurabili
#
# Acest fișier definește valorile implicite pentru toate
# opțiunile MDSSC. Modifică valorile de aici pentru a schimba
# comportamentul pipeline-ului fără a edita cicd.yml.
#
# Prioritate (de la mare la mică):
#   1. GitHub Secrets        (MDSSC_INSTANCE, MDSSC_API_KEY)
#   2. workflow_dispatch inputs (la rulare manuală din GitHub UI)
#   3. Valorile din acest fișier  ← editează aici
# ============================================================

# ── Conexiune MDSSC ───────────────────────────────────────────────────────────
# URL-ul instanței MDSSC (ex: http://35.156.106.42)
# NOTĂ: MDSSC_INSTANCE și MDSSC_API_KEY vin din GitHub Secrets, nu de aici.
: "${MDSSC_API_KEY_HEADER:=apikey}"          # numele header-ului pentru API key

# ── Workflow MDSSC ────────────────────────────────────────────────────────────
# Lasă gol pentru auto-detectare (primul workflow disponibil).
: "${MDSSC_WORKFLOW_ID:=}"

# StorageId și RepositoryId — auto-detectate din workflow dacă nu sunt setate.
# Pot fi setate explicit ca GitHub Secrets (MDSSC_STORAGE_ID, MDSSC_REPOSITORY_ID)
# dacă auto-detectarea nu funcționează.
: "${MDSSC_STORAGE_ID:=}"
: "${MDSSC_REPOSITORY_ID:=}"

# ── Threshold vulnerabilități ─────────────────────────────────────────────────
# Severitate minimă care eșuează build-ul: none | low | medium | high | critical
: "${VULNERABILITY_THRESHOLD:=none}"

# ── Opțiuni fail ─────────────────────────────────────────────────────────────
: "${FAIL_ON_SECRET:=false}"                  # eșuează dacă găsește secrete hardcodate
: "${FAIL_ON_MALWARE:=false}"                 # eșuează dacă găsește malware

# ── Timing scan ──────────────────────────────────────────────────────────────
: "${MDSSC_SCAN_TIMEOUT:=900}"               # secunde maxime de așteptare pentru scan
: "${MDSSC_POLL_INTERVAL:=10}"               # secunde între request-uri de poll

# ── Limite fișiere (artifact scan) ───────────────────────────────────────────
: "${MDSSC_MAX_UPLOAD_MB:=100}"              # dimensiune maximă fișier pentru upload (MB)
: "${MDSSC_SKIP_LARGE_ARTIFACTS:=true}"      # sare artefactele prea mari (dacă false → fail)

# ── Branch (source scan indirect) ────────────────────────────────────────────
# Lasă gol pentru a folosi branch-ul curent al commit-ului care a declanșat pipeline-ul.
: "${MDSSC_BRANCH:=}"
