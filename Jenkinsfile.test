// MDSSC Plugin Integration Test
// Run automatically by ci/jenkins/start-jenkins.sh inside a temporary Jenkins Docker instance.
//
// Tests:
//   1. Sanity check — credentials and env vars configured correctly
//   2. SourceCodeScanStep — indirect GitHub repo scan via MDSSC
//   3. ArtifactScanStep  — direct .hpi file scan via MDSSC
//
// If any stage fails → build FAILURE → start-jenkins.sh returns exit 1

pipeline {
    agent any

    options {
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {
        stage('Sanity Check') {
            steps {
                script {
                    def instanceUrl = env.MDSSC_INSTANCE_URL
                    if (!instanceUrl || instanceUrl.trim().isEmpty()) {
                        error('MDSSC_INSTANCE_URL is not configured — check jenkins.yaml and the Docker environment variables')
                    }
                    echo "MDSSC Instance: ${instanceUrl}"
                    echo "Credential ID : mdssc-api-key"
                    echo "Plugin version: verified at runtime via the scan steps"
                }
            }
        }

        stage('Source Code Scan') {
            steps {
                echo 'Starting SourceCodeScanStep (indirect scan — MDSSC pulls from GitHub)...'
                step([$class: 'io.jenkins.plugins.mdssc.SourceCodeScanStep',
                    mdsscInstance         : env.MDSSC_INSTANCE_URL,
                    credentialsId         : 'mdssc-api-key',
                    branch                : 'main',
                    workflowId            : (env.MDSSC_WORKFLOW_ID ?: ''),
                    connectionId          : '',
                    repository            : '',
                    vulnerabilityThreshold: 'none',
                    failOnSecret          : false,
                    failOnMalware         : false,
                    scanTimeout           : 600,
                    pollInterval          : 10
                ])
            }
        }

        stage('Artifact Scan') {
            steps {
                echo 'Preparing the .hpi file for the artifact scan...'
                sh 'cp /tmp/mdssc-scanner.hpi mdssc-scanner.hpi'
                echo 'Starting ArtifactScanStep (direct .hpi upload scan)...'
                step([$class: 'io.jenkins.plugins.mdssc.ArtifactScanStep',
                    mdsscInstance         : env.MDSSC_INSTANCE_URL,
                    credentialsId         : 'mdssc-api-key',
                    filePath              : 'mdssc-scanner.hpi',
                    workflowId            : (env.MDSSC_WORKFLOW_ID ?: ''),
                    vulnerabilityThreshold: 'none',
                    failOnSecret          : false,
                    failOnMalware         : false,
                    scanTimeout           : 600,
                    pollInterval          : 10,
                    maxFileSizeMb         : 100
                ])
            }
        }
    }

    post {
        success {
            echo '=========================================='
            echo '  MDSSC PLUGIN TEST: PASSED'
            echo '  Source scan + Artifact scan OK.'
            echo '=========================================='
        }
        failure {
            echo '=========================================='
            echo '  MDSSC PLUGIN TEST: FAILED'
            echo '  Check the console output above.'
            echo '=========================================='
        }
    }
}
