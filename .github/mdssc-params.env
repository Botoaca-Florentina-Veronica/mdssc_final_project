# ============================================================
# MDSSC Pipeline — Configurable parameters
#
# This file defines the default values for all MDSSC options.
# Edit the values here to change the pipeline behavior without
# editing cicd.yml.
#
# Priority (high to low):
#   1. GitHub Secrets        (MDSSC_INSTANCE, MDSSC_API_KEY)
#   2. workflow_dispatch inputs (manual run from the GitHub UI)
#   3. The values in this file  ← edit here
#
# NOTE: Pipeline toggles are NOT here, but set as GitHub Variables
# (Settings → Secrets and variables → Actions → Variables):
#   MDSSC_DAILY_SCAN = true  → enables the scheduled daily scan (06:00 UTC)
#   MDSSC_RELEASE    = true  → enables the .hpi GitHub release on push to main
# ============================================================

# ── MDSSC connection ──────────────────────────────────────────────────────────
# URL of the MDSSC instance (e.g. http://35.156.106.42)
# NOTE: MDSSC_INSTANCE and MDSSC_API_KEY come from GitHub Secrets, not from here.
: "${MDSSC_API_KEY_HEADER:=apikey}"          # name of the API key header

# ── MDSSC Workflow ────────────────────────────────────────────────────────────
# Leave empty for auto-detection (first available workflow).
: "${MDSSC_WORKFLOW_ID:=}"

# StorageId and RepositoryId — auto-detected from the workflow if not set.
# Can be set explicitly as GitHub Secrets (MDSSC_STORAGE_ID, MDSSC_REPOSITORY_ID)
# if auto-detection does not work.
: "${MDSSC_STORAGE_ID:=}"
: "${MDSSC_REPOSITORY_ID:=}"

# ── Vulnerability threshold ───────────────────────────────────────────────────
# Minimum severity that fails the build: none | low | medium | high | critical
: "${VULNERABILITY_THRESHOLD:=none}"

# ── Fail options ─────────────────────────────────────────────────────────────
: "${FAIL_ON_SECRET:=false}"                  # fail if it finds hardcoded secrets
: "${FAIL_ON_MALWARE:=false}"                 # fail if it finds malware

# ── Scan timing ──────────────────────────────────────────────────────────────
: "${MDSSC_SCAN_TIMEOUT:=900}"               # max seconds to wait for the scan
: "${MDSSC_POLL_INTERVAL:=10}"               # seconds between poll requests

# ── File limits (artifact scan) ──────────────────────────────────────────────
: "${MDSSC_MAX_UPLOAD_MB:=100}"              # maximum file size for upload (MB)
: "${MDSSC_SKIP_LARGE_ARTIFACTS:=true}"      # skip artifacts that are too large (if false → fail)

# ── Branch (indirect source scan) ────────────────────────────────────────────
# Leave empty to use the current branch of the commit that triggered the pipeline.
: "${MDSSC_BRANCH:=}"
